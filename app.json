{
  "expo": {
    "name": "4mylove",
    "slug": "4mylove",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon-dark.png",
    "scheme": "4mylove",
    "userInterfaceStyle": "dark",
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#262626",
        "foregroundImage": "./assets/images/android-icon-foreground-dark.png",
        "backgroundImage": "./assets/images/android-icon-background-dark.png",
        "monochromeImage": "./assets/images/android-icon-monochrome-dark.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.joaogameplay.x4mylove"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#262626",
          "image": "./assets/images/splash-icon-dark.png",
          "dark": {
            "backgroundColor": "#262626",
            "image": "./assets/images/splash-icon-dark.png"
          },
          "imageWidth": 76
        }
      ],
      "expo-font",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "75c6bb14-8e7a-42a3-9d31-ee8e947d2adf"
      }
    },
    "owner": "joaogameplays-team",
    "ios": {
      "bundleIdentifier": "com.joaogameplay.x4mylove"
    }
  }
}
